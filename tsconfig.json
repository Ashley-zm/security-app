{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "types": ["@dcloudio/types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "App.vue",
    "main.ts",
    "env.d.ts",
    "pages/**/*.vue",
    "api/**/*.ts",
    "components/**/*.vue",
    "stores/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts"
  ],
  "references": []
}
